{
  "manifest_version": 3,
  "name": "Innergy PO → Mail",
  "version": "1.0.0",
  "description": "Adds a button beside \"Export Custom PDF\" on Innergy PO pages that exports the PDF and drafts an email with it attached.",
  "key": "",
  "permissions": ["downloads", "nativeMessaging", "storage"],
  "host_permissions": ["https://app.innergy.com/*"],
  "background": { "service_worker": "background.js" },
  "options_ui": { "page": "options.html", "open_in_tab": true },
  "content_scripts": [
    {
      "matches": ["https://app.innergy.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
