# Extension signing key — NEVER commit (would let anyone forge the extension ID)
native-host/extension_key.pem

# Generated by install.sh (machine-specific absolute paths)
native-host/run-host.sh

# Runtime log written by the native host
native-host/host.log

# Windows batch wrapper (machine-specific)
native-host/run-host.bat

# Compiled Windows native host binary
native-host/innergy_mailer_host_win.exe

# PyInstaller build artifacts
native-host/build/
native-host/dist/
native-host/innergy_mailer_host_win.spec

# Packed extension output
dist/

# OAuth token cache -- contains credentials, never commit
native-host/graph_token_cache.json
native-host/auth_pending.json

# Python / macOS / editor noise
__pycache__/
*.pyc
.DS_Store

# Claude Code session data
.claude/
